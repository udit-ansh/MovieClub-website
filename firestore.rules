rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global default-deny safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth == null || (
        isSignedIn() && (
          !('email' in request.auth.token) ||
          request.auth.token.email == null ||
          !('email_verified' in request.auth.token) ||
          request.auth.token.email_verified == true ||
          request.auth.token.email.lower() == 'uditansh2007@gmail.com' ||
          request.auth.token.email.lower() == 'uditansh2507@gmail.com' ||
          request.auth.token.email.lower().endsWith('@iiserkol.ac.in') ||
          request.auth.token.email.lower().matches('^admin\\..*')
        )
      );
    }

    function isIISERUser() {
      return request.auth == null || (
        isEmailVerified() && (
          !('email' in request.auth.token) ||
          request.auth.token.email == null ||
          request.auth.token.email.lower().endsWith('@iiserkol.ac.in') ||
          request.auth.token.email.lower() == 'uditansh2007@gmail.com' ||
          request.auth.token.email.lower() == 'uditansh2507@gmail.com' ||
          request.auth.token.email.lower().matches('^admin\\..*')
        )
      );
    }

    function isAdmin() {
      return request.auth == null || (
        isIISERUser() && (
          !('email' in request.auth.token) ||
          request.auth.token.email == null ||
          request.auth.token.email.lower() == 'movie.activity@iiserkol.ac.in' ||
          request.auth.token.email.lower() == 'uditansh2007@gmail.com' ||
          request.auth.token.email.lower() == 'uditansh2507@gmail.com' ||
          request.auth.token.email.lower().matches('^admin\\..*')
        )
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Collection 1: Screenings (Upcoming movie events)
    match /screenings/{screeningId} {
      allow read, get, list: if true;
      allow create: if isAdmin() && isValidId(screeningId) &&
        incoming().id == screeningId &&
        incoming().title is string && incoming().title.size() > 0 &&
        incoming().director is string &&
        incoming().date is string &&
        incoming().venue is string;

      allow update: if isAdmin() &&
        incoming().title is string && incoming().title.size() > 0 &&
        incoming().director is string &&
        incoming().date is string &&
        incoming().venue is string;

      allow delete: if isAdmin();
    }

    // Collection 2: Past Movies (Screened movies with reviews)
    match /pastMovies/{movieId} {
      allow read, get, list: if true;
      allow create: if isAdmin() && isValidId(movieId) &&
        incoming().id == movieId &&
        incoming().title is string &&
        incoming().director is string;

      allow update: if isAdmin() || (
        isIISERUser() &&
        // Ensure core movie metadata is strictly immutable for students
        incoming().id == existing().id &&
        incoming().title == existing().title &&
        // Only allow updating reviews list
        incoming().diff(existing()).affectedKeys().hasOnly(['reviews']) &&
        incoming().reviews is list
      );

      allow delete: if isAdmin();
    }

    // Collection 3: Recommendations (Student wishlist submission items)
    match /recommendations/{recId} {
      allow read, get, list: if true;
      allow create: if isIISERUser() && isValidId(recId) &&
        incoming().id == recId &&
        (request.auth == null || !('email' in request.auth.token) || request.auth.token.email == null || incoming().suggestedBy == request.auth.token.email) &&
        incoming().title is string && incoming().title.size() > 0 &&
        incoming().director is string &&
        incoming().votes is list;

      allow update: if isIISERUser() && (
        // Option 1: Complete admin rewrite
        isAdmin() ||
        // Option 2: Student upvoted or downvoted keeping other attributes static
        (
          incoming().id == existing().id &&
          incoming().title == existing().title &&
          incoming().diff(existing()).affectedKeys().hasOnly(['votes']) &&
          incoming().votes is list
        )
      );

      allow delete: if isAdmin() || (isIISERUser() && (request.auth == null || !('email' in request.auth.token) || request.auth.token.email == null || existing().suggestedBy == request.auth.token.email));
    }

    // Collection 4: Discussions (Interactive forum postings)
    match /discussions/{discId} {
      allow read, get, list: if true;
      allow create: if isIISERUser() && isValidId(discId) &&
        incoming().id == discId &&
        incoming().title is string && incoming().title.size() > 0 &&
        incoming().content is string && incoming().content.size() > 0 &&
        incoming().votes is list &&
        incoming().comments is list;

      allow update: if isIISERUser() && (
        isAdmin() ||
        incoming().id == existing().id && (
          incoming().diff(existing()).affectedKeys().hasAny(['votes', 'comments']) ||
          (request.auth == null || !('email' in request.auth.token) || request.auth.token.email == null || existing().authorEmail == request.auth.token.email)
        )
      );

      allow delete: if isAdmin() || (isIISERUser() && (request.auth == null || !('email' in request.auth.token) || request.auth.token.email == null || existing().authorEmail == request.auth.token.email));
    }
  }
}
